<!-- src/HuntLoader/App.xaml -->
<Application x:Class="HuntLoader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HuntLoader">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Bool конвертеры -->
            <local:BoolToVisibilityConverter        x:Key="BoolToVis"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <local:InverseBoolConverter             x:Key="InverseBool"/>

            <!-- Цвет и стиль -->
            <local:LineTypeToColorConverter         x:Key="LineTypeToColor"/>
            <local:BoolToEnabledConverter           x:Key="BoolToEnabled"/>
            <local:StringToColorBrushConverter      x:Key="StringToColorBrush"/>
            <local:ActiveAccountBrushConverter      x:Key="ActiveAccountBrush"/>

            <!-- ✅ НОВЫЙ: HEX → Color для кастомизации -->
            <local:HexToColorConverter              x:Key="HexToColor"/>

            <!-- Ширина прогресс-бара -->
            <local:PercentToWidthConverter          x:Key="PercentToWidth"/>

            <!-- RadioButton привязка -->
            <local:EqualityConverter                x:Key="EqualityConverter"/>

            <!-- Null / пусто / ноль -->
            <local:NullToVisibilityConverter        x:Key="NullToVis"/>
            <local:StringToVisibilityConverter      x:Key="StringToVis"/>
            <local:ZeroToVisibilityConverter        x:Key="ZeroToVis"/>

            <!-- Enum → строка -->
            <local:ModLoaderToStringConverter       x:Key="ModLoaderToString"/>
            <local:AccountTypeToIconConverter       x:Key="AccountTypeToIcon"/>

            <!-- Время -->
            <local:TimeSpanToStringConverter        x:Key="TimeSpanToString"/>
            <local:DateTimeToRelativeConverter      x:Key="DateTimeToRelative"/>
            <local:MemoryToStringConverter          x:Key="MemoryToString"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>