<!-- src/HuntLoader/MainWindow.xaml -->
<Window x:Class="HuntLoader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HuntLoader.ViewModels"
        xmlns:pages="clr-namespace:HuntLoader.Views.Pages"
        Title="Hunt Loader"
        Width="1280" Height="760"
        MinWidth="1024" MinHeight="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <!-- Орбы -->
                    <DoubleAnimation Storyboard.TargetName="Orb1T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="120" Duration="0:0:14">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb1T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="80" Duration="0:0:10">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="-100" Duration="0:0:16">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-60" Duration="0:0:12">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb3T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="70" Duration="0:0:18">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb3T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="90" Duration="0:0:15">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Частицы -->
                    <DoubleAnimation Storyboard.TargetName="p1"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-50" Duration="0:0:5">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="p2"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-35" Duration="0:0:3.5">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="p3"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-55" Duration="0:0:6">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="p4"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-30" Duration="0:0:4">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="p5"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-40" Duration="0:0:5.5">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <pages:HomePage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <pages:ProfilesPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModsViewModel}">
            <pages:ModsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AltManagerViewModel}">
            <pages:AltManagerPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <pages:SettingsPage/>
        </DataTemplate>
    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect Color="#000000" BlurRadius="80"
                          ShadowDepth="0" Opacity="0.9"/>
    </Window.Effect>

    <!-- Внешний border — скругление окна -->
    <Border CornerRadius="22" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#05050E" Offset="0"/>
                <GradientStop Color="#08081A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ ФОН — орбы и частицы ═══ -->
            <Canvas Grid.ColumnSpan="2" IsHitTestVisible="False" ClipToBounds="True">

                <!-- Орб 1 — фиолетовый -->
                <Ellipse Width="1000" Height="1000"
                         Canvas.Right="-400" Canvas.Top="-500" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C5CBF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Orb1T"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Орб 2 — синий -->
                <Ellipse Width="800" Height="800"
                         Canvas.Left="-300" Canvas.Bottom="-350" Opacity="0.05">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#5B8FE8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Orb2T"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Орб 3 — розовый -->
                <Ellipse Width="600" Height="600"
                         Canvas.Left="550" Canvas.Top="320" Opacity="0.04">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#E8609A" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Orb3T"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Частицы -->
                <Ellipse Width="5" Height="5"
                         Canvas.Left="150" Canvas.Top="200" Opacity="0.35">
                    <Ellipse.Fill><SolidColorBrush Color="#7C5CBF"/></Ellipse.Fill>
                    <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="p1"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="3" Height="3"
                         Canvas.Left="600" Canvas.Top="350" Opacity="0.28">
                    <Ellipse.Fill><SolidColorBrush Color="#5B8FE8"/></Ellipse.Fill>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="p2"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="4" Height="4"
                         Canvas.Left="900" Canvas.Top="150" Opacity="0.22">
                    <Ellipse.Fill><SolidColorBrush Color="#E8609A"/></Ellipse.Fill>
                    <Ellipse.Effect><BlurEffect Radius="1"/></Ellipse.Effect>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="p3"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="2" Height="2"
                         Canvas.Left="400" Canvas.Top="550" Opacity="0.22">
                    <Ellipse.Fill><SolidColorBrush Color="#7C5CBF"/></Ellipse.Fill>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="p4"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="3" Height="3"
                         Canvas.Left="750" Canvas.Top="480" Opacity="0.20">
                    <Ellipse.Fill><SolidColorBrush Color="#4ECDC4"/></Ellipse.Fill>
                    <Ellipse.RenderTransform><TranslateTransform x:Name="p5"/></Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <!-- ═══ LIQUID GLASS САЙДБАР ═══ -->
            <Border Grid.Column="0" ClipToBounds="True">
                <!-- Тёмная подложка сайдбара -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#CC030308" Offset="0"/>
                        <GradientStop Color="#CC05050F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Glass слой сайдбара -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#12FFFFFF" Offset="0"/>
                                <GradientStop Color="#04FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Shimmer highlight вверху сайдбара -->
                    <Border Height="120" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#18FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Правая граница — градиентная -->
                    <Border HorizontalAlignment="Right" Width="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                <GradientStop Color="#15FFFFFF" Offset="0.4"/>
                                <GradientStop Color="#25E8609A" Offset="0.75"/>
                                <GradientStop Color="#204ECDC4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Основной контент сайдбара -->
                    <DockPanel LastChildFill="False">

                        <!-- ── ШАПКА — Drag зона ── -->
                        <Border DockPanel.Dock="Top" Height="88"
                                Cursor="SizeAll"
                                MouseLeftButtonDown="TitleBar_MouseDown"
                                Padding="20,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Лого кружок — Liquid Glass -->
                                <Grid Width="46" Height="46">
                                    <!-- Тёмная подложка -->
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1A1A32" Offset="0"/>
                                                <GradientStop Color="#0D0D22" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Glass слой -->
                                    <Ellipse Opacity="0.6">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                                <GradientStop Color="#05FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Верхний блик -->
                                    <Ellipse Width="32" Height="16"
                                             VerticalAlignment="Top" Margin="0,4,0,0"
                                             Opacity="0.5">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#60FFFFFF" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Граница -->
                                    <Ellipse StrokeThickness="1">
                                        <Ellipse.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#40FFFFFF" Offset="0"/>
                                                <GradientStop Color="#10FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                    <!-- Glow -->
                                    <Ellipse Width="46" Height="46">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#7C5CBF"
                                                              BlurRadius="20"
                                                              ShadowDepth="0"
                                                              Opacity="0.5"/>
                                        </Ellipse.Effect>
                                        <Ellipse.Fill>Transparent</Ellipse.Fill>
                                    </Ellipse>
                                    <!-- Текст -->
                                    <TextBlock Text="HL"
                                               FontSize="14" FontWeight="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#C0B0FF" Offset="0"/>
                                                <GradientStop Color="#80B0FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Grid>

                                <!-- Название -->
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center"
                                            IsHitTestVisible="False">
                                    <TextBlock Text="Hunt Loader"
                                               FontSize="15" FontWeight="Black"
                                               Foreground="#F0F0FF"/>
                                    <TextBlock Text="v2.0.0"
                                               FontSize="10"
                                               Foreground="#30FFFFFF"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Разделитель -->
                        <Border DockPanel.Dock="Top" Height="1" Margin="18,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#25FFFFFF" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Метка меню -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="НАВИГАЦИЯ"
                                   Foreground="#20FFFFFF"
                                   FontSize="9" FontWeight="Black"
                                   Margin="24,16,0,8"/>

                        <!-- ── НАВИГАЦИЯ ── -->
                        <StackPanel DockPanel.Dock="Top" Margin="8,0,8,0">

                            <!-- Главная -->
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NavHomeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#20FFFFFF" Offset="0"/>
                                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Viewbox Width="16" Height="16">
                                            <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"
                                                  Stretch="Uniform">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#9B7FE8" Offset="0"/>
                                                        <GradientStop Color="#5B8FE8" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Главная"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#E0E0FF"/>
                                        <TextBlock Text="Запуск игры"
                                                   FontSize="10"
                                                   Foreground="#30FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Профили -->
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NavProfilesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#18FFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Viewbox Width="16" Height="16">
                                            <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                                  Stretch="Uniform">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#5B8FE8" Offset="0"/>
                                                        <GradientStop Color="#4ECDC4" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Профили"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#E0E0FF"/>
                                        <TextBlock Text="Версии игры"
                                                   FontSize="10"
                                                   Foreground="#30FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Моды -->
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NavModsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#18FFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Viewbox Width="16" Height="16">
                                            <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"
                                                  Stretch="Uniform">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#E8609A" Offset="0"/>
                                                        <GradientStop Color="#7C5CBF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Моды"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#E0E0FF"/>
                                        <TextBlock Text="Modrinth · CurseForge"
                                                   FontSize="10"
                                                   Foreground="#30FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Аккаунты -->
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NavAltManagerCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#18FFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Viewbox Width="16" Height="16">
                                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                                  Stretch="Uniform">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4ECDC4" Offset="0"/>
                                                        <GradientStop Color="#5B8FE8" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Аккаунты"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#E0E0FF"/>
                                        <TextBlock Text="Microsoft · Offline"
                                                   FontSize="10"
                                                   Foreground="#30FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── НИЗ САЙДБАРА ── -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">

                            <!-- Разделитель -->
                            <Border Height="1" Margin="10,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#18FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Настройки -->
                            <Button Style="{StaticResource NavBtn}"
                                    Command="{Binding NavSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#14FFFFFF" Offset="0"/>
                                                <GradientStop Color="#05FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Viewbox Width="16" Height="16">
                                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                                  Stretch="Uniform" Fill="#60FFFFFF"/>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Настройки"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#80FFFFFF"/>
                                        <TextBlock Text="Конфигурация"
                                                   FontSize="10"
                                                   Foreground="#25FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Разделитель -->
                            <Border Height="1" Margin="10,6">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#12FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- macOS кнопки окна -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,0,0">
                                <!-- Закрыть — красный -->
                                <Button Style="{StaticResource WinBtnClose}"
                                        Click="CloseClick"
                                        Margin="0,0,8,0"
                                        ToolTip="Закрыть"/>
                                <!-- Свернуть — жёлтый -->
                                <Button Style="{StaticResource WinBtnMinimize}"
                                        Click="MinimizeClick"
                                        Margin="0,0,8,0"
                                        ToolTip="Свернуть"/>
                                <!-- Развернуть — зелёный (декоративный) -->
                                <Button Style="{StaticResource WinBtnMaximize}"
                                        ToolTip="Развернуть"
                                        Click="MaximizeClick"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- ═══ КОНТЕНТ — правая часть ═══ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Drag зона вверху контента -->
                <Border Grid.Row="0"
                        MouseLeftButtonDown="TitleBar_MouseDown"
                        Cursor="SizeAll"
                        Background="Transparent"/>

                <!-- Страницы с анимацией -->
                <ContentControl x:Name="PageContent"
                                Grid.Row="1"
                                Content="{Binding CurrentPage}"
                                Background="Transparent">
                    <ContentControl.RenderTransform>
                        <TranslateTransform/>
                    </ContentControl.RenderTransform>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>