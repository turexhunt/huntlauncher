<!-- src/HuntLoader/Views/Pages/SettingsPage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32">

            <!-- Заголовок -->
            <TextBlock FontSize="26" FontWeight="Black" Margin="0,0,0,4">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#9B7FE8" Offset="0"/>
                        <GradientStop Color="#5B8FE8" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <Run Text="Настройки"/>
            </TextBlock>
            <TextBlock Text="Кастомизация и параметры лаунчера"
                       Foreground="#30FFFFFF" FontSize="13"
                       Margin="0,0,0,28"/>

            <UniformGrid Columns="2">

                <!-- ═══ ЛЕВАЯ КОЛОНКА ═══ -->
                <StackPanel Margin="0,0,10,0">

                    <!-- Внешний вид — Glass карточка -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,14"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC0A0A1E" Offset="0"/>
                                <GradientStop Color="#CC070714" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="30"
                                              ShadowDepth="4" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="🎨" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Внешний вид"
                                           Foreground="#F0F0FF"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <CheckBox Content="Частицы"
                                      IsChecked="{Binding ShowParticles}"
                                      Foreground="#D0D0F0" FontSize="13"
                                      Margin="0,0,0,8"/>
                            <CheckBox Content="Анимации"
                                      IsChecked="{Binding AnimationsEnabled}"
                                      Foreground="#D0D0F0" FontSize="13"
                                      Margin="0,0,0,18"/>

                            <TextBlock Foreground="#40FFFFFF" FontSize="11" Margin="0,0,0,6">
                                <Run Text="Прозрачность фона: "/>
                                <Run Text="{Binding BackgroundOpacity,
                                            StringFormat='{}{0:P0}', Mode=OneWay}"
                                     Foreground="#9B7FE8" FontWeight="Bold"/>
                            </TextBlock>
                            <Slider Minimum="0.3" Maximum="1"
                                    Value="{Binding BackgroundOpacity}"
                                    Foreground="#7C5CBF" Margin="0,0,0,18"/>

                            <TextBlock Foreground="#40FFFFFF" FontSize="11" Margin="0,0,0,6">
                                <Run Text="Масштаб интерфейса: "/>
                                <Run Text="{Binding UiScale,
                                            StringFormat='{}{0:P0}', Mode=OneWay}"
                                     Foreground="#9B7FE8" FontWeight="Bold"/>
                            </TextBlock>
                            <Slider Minimum="0.8" Maximum="1.5"
                                    Value="{Binding UiScale}"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    Foreground="#7C5CBF" Margin="0,0,0,18"/>

                            <Button Padding="12,10" Cursor="Hand"
                                    Command="{Binding BrowseBgCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="10"
                                                BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#06FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#25FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="🖼 Выбрать фон"
                                           Foreground="#C0C0F0" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Кастомизация цветов — Glass -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,14"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC0A0A1E" Offset="0"/>
                                <GradientStop Color="#CC070714" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="30"
                                              ShadowDepth="4" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="🌈" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Кастомизация цветов"
                                           Foreground="#F0F0FF"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Пресет темы"
                                       Foreground="#40FFFFFF" FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Border CornerRadius="10" BorderThickness="1" Margin="0,0,0,18">
                                <Border.Background>
                                    <SolidColorBrush Color="#08FFFFFF"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <ComboBox ItemsSource="{Binding ThemePresets}"
                                          SelectedItem="{Binding SelectedTheme}"
                                          Background="Transparent"
                                          Foreground="#E0E0FF"
                                          BorderThickness="0"
                                          Padding="10,8" FontSize="12"/>
                            </Border>

                            <TextBlock Text="Основной цвет акцента"
                                       Foreground="#40FFFFFF" FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#08FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <TextBox Background="Transparent"
                                             Foreground="#F0F0FF"
                                             CaretBrush="#9B7FE8"
                                             BorderThickness="0"
                                             Padding="10,8" FontSize="12"
                                             FontFamily="Consolas"
                                             Text="{Binding AccentColor,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding PickAccentColorCommand}"
                                        Cursor="Hand" Height="36">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <SolidColorBrush
                                                        Color="{Binding AccentColor,
                                                                Converter={StaticResource HexToColor}}"/>
                                                </Border.Background>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <TextBlock Text="Дополнительный цвет акцента"
                                       Foreground="#40FFFFFF" FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#08FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <TextBox Background="Transparent"
                                             Foreground="#F0F0FF"
                                             CaretBrush="#9B7FE8"
                                             BorderThickness="0"
                                             Padding="10,8" FontSize="12"
                                             FontFamily="Consolas"
                                             Text="{Binding AccentColor2,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding PickAccentColor2Command}"
                                        Cursor="Hand" Height="36">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Background>
                                                    <SolidColorBrush
                                                        Color="{Binding AccentColor2,
                                                                Converter={StaticResource HexToColor}}"/>
                                                </Border.Background>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <TextBlock Text="Предпросмотр градиента"
                                       Foreground="#40FFFFFF" FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Border Height="34" CornerRadius="10" BorderThickness="1">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{Binding AccentColor,
                                                              Converter={StaticResource HexToColor}}"
                                                      Offset="0"/>
                                        <GradientStop Color="{Binding AccentColor2,
                                                              Converter={StaticResource HexToColor}}"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Лаунчер — Glass -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,14"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC0A0A1E" Offset="0"/>
                                <GradientStop Color="#CC070714" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="30"
                                              ShadowDepth="4" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="⚙" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Лаунчер"
                                           Foreground="#F0F0FF"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <CheckBox Content="Закрывать при запуске игры"
                                      IsChecked="{Binding CloseOnLaunch}"
                                      Foreground="#D0D0F0" FontSize="13"
                                      Margin="0,0,0,8"/>
                            <CheckBox Content="Показывать снапшоты"
                                      IsChecked="{Binding ShowSnapshots}"
                                      Foreground="#D0D0F0" FontSize="13"
                                      Margin="0,0,0,8"/>
                            <CheckBox Content="Discord Rich Presence"
                                      IsChecked="{Binding DiscordRpc}"
                                      Foreground="#D0D0F0" FontSize="13"
                                      Margin="0,0,0,18"/>

                            <TextBlock Foreground="#40FFFFFF" FontSize="11" Margin="0,0,0,6">
                                <Run Text="Потоков загрузки: "/>
                                <Run Text="{Binding ConcurrentDownloads, Mode=OneWay}"
                                     Foreground="#9B7FE8" FontWeight="Bold"/>
                            </TextBlock>
                            <Slider Minimum="1" Maximum="16"
                                    Value="{Binding ConcurrentDownloads}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Foreground="#7C5CBF" Margin="0,0,0,18"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Padding="12,9" Cursor="Hand"
                                        Command="{Binding OpenAppDataCommand}"
                                        Margin="0,0,8,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#12FFFFFF"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="📁 AppData"
                                               Foreground="#C0C0F0" FontSize="12"/>
                                </Button>
                                <Button Padding="12,9" Cursor="Hand"
                                        Command="{Binding ClearCacheCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#12FFFFFF"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="🗑 Кеш"
                                               Foreground="#C0C0F0" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ ПРАВАЯ КОЛОНКА ═══ -->
                <StackPanel Margin="10,0,0,0">

                    <!-- Java — Glass -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,14"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC0A0A1E" Offset="0"/>
                                <GradientStop Color="#CC070714" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="30"
                                              ShadowDepth="4" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="☕" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Java"
                                           Foreground="#F0F0FF"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Оставь пустым для автоопределения"
                                       Foreground="#25FFFFFF" FontSize="11"
                                       Margin="0,0,0,18"/>
                            <TextBlock Text="Путь к javaw.exe"
                                       Foreground="#40FFFFFF" FontSize="11"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="10" BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush Color="#08FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <TextBox Background="Transparent"
                                             Foreground="#F0F0FF"
                                             CaretBrush="#9B7FE8"
                                             BorderThickness="0"
                                             Padding="10,8" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding GlobalJavaPath,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <Button Grid.Column="2" Cursor="Hand"
                                        Command="{Binding BrowseJavaCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="10" BorderThickness="1">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#12FFFFFF"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Viewbox Width="16" Height="16" Margin="0,6">
                                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                                          Stretch="Uniform" Fill="#80FFFFFF"/>
                                                </Viewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            <Button Padding="12,11" Cursor="Hand"
                                    Command="{Binding CheckJavaCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#7C5CBF" Offset="0"/>
                                                    <GradientStop Color="#5B8FE8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#7C5CBF"
                                                                  BlurRadius="16"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.5"/>
                                            </Border.Effect>
                                            <!-- Glass highlight -->
                                            <Grid>
                                                <Border CornerRadius="12" Height="12"
                                                        VerticalAlignment="Top"
                                                        Margin="1,1,1,0" Opacity="0.4">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#40FFFFFF" Offset="0"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="☕ Проверить Java"
                                           Foreground="White" FontSize="13"
                                           FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- О лаунчере — Glass -->
                    <Border CornerRadius="20" Padding="22" Margin="0,0,0,14"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC0A0A1E" Offset="0"/>
                                <GradientStop Color="#CC070714" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="30"
                                              ShadowDepth="4" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="ℹ" FontSize="16" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="О лаунчере"
                                           Foreground="#F0F0FF"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Инфо строки -->
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,16"
                                    BorderThickness="1">
                                <Border.Background>
                                    <SolidColorBrush Color="#08FFFFFF"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#18FFFFFF" Offset="0"/>
                                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Версия:"
                                                   Foreground="#30FFFFFF" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="2.0.0"
                                                   Foreground="#F0F0FF" FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Платформа:"
                                                   Foreground="#30FFFFFF" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text=".NET 8 / WPF"
                                                   Foreground="#F0F0FF" FontSize="12"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="AppData:"
                                                   Foreground="#30FFFFFF" FontSize="12"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="%APPDATA%\.huntloader"
                                                   Foreground="#9B7FE8" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Discord -->
                            <Button Padding="12,11" Cursor="Hand"
                                    Command="{Binding OpenDiscordCommand}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#5865F2" Offset="0"/>
                                                    <GradientStop Color="#4752C4" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Border CornerRadius="12" Height="12"
                                                        VerticalAlignment="Top"
                                                        Margin="1,1,1,0" Opacity="0.4">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#40FFFFFF" Offset="0"/>
                                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Viewbox Width="16" Height="16"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center">
                                                        <Path Fill="White"
                                                              Data="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.033.055a19.9 19.9 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                                                    </Viewbox>
                                                    <TextBlock Text="Discord сервер"
                                                               Foreground="White" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Сброс — danger glass -->
                            <Button Padding="12,10" Cursor="Hand"
                                    Command="{Binding ResetSettingsCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="12"
                                                BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#20F87171" Offset="0"/>
                                                    <GradientStop Color="#08F87171" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#F87171" Opacity="0.35"/>
                                            </Border.BorderBrush>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="🔄 Сбросить настройки"
                                           Foreground="#F87171" FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </UniformGrid>

            <!-- Статус — Glass -->
            <Border CornerRadius="12" Padding="16,10"
                    Margin="0,14,0,0" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#12FFFFFF" Offset="0"/>
                        <GradientStop Color="#04FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#20FFFFFF" Offset="0"/>
                        <GradientStop Color="#06FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                           Foreground="#50FFFFFF" FontSize="12"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>