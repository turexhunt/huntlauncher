<!-- src/HuntLoader/Views/Pages/LoadingPage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.LoadingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="OnLoaded">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>

                    <!-- ═══ КОЛЬЦА ═══ -->
                    <DoubleAnimation Storyboard.TargetName="Ring1Rotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:10"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="Ring2Rotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="360" To="0" Duration="0:0:7"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="Ring3Rotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:14"
                                     RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="Ring4Rotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="360" To="0" Duration="0:0:20"
                                     RepeatBehavior="Forever"/>

                    <!-- ═══ ПУЛЬСАЦИЯ ЛОГО ═══ -->
                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.94" To="1.06"
                                     Duration="0:0:2.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.94" To="1.06"
                                     Duration="0:0:2.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- ═══ СВЕЧЕНИЕ ЛОГО ═══ -->
                    <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="25" To="60"
                                     Duration="0:0:2.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.6" To="1.0"
                                     Duration="0:0:2.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"/>

                    <!-- Внешнее свечение орба -->
                    <DoubleAnimation Storyboard.TargetName="OuterGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="40" To="90"
                                     Duration="0:0:3"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="OuterGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="0.4"
                                     Duration="0:0:3"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"/>

                    <!-- ═══ ОРБЫ ФОНА ═══ -->
                    <DoubleAnimation Storyboard.TargetName="Orb1T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="120" Duration="0:0:8"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb1T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="70" Duration="0:0:6"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb1"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.05" To="0.14" Duration="0:0:5"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="Orb2T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="-100" Duration="0:0:10"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-60" Duration="0:0:7"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb2"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.04" To="0.10" Duration="0:0:7"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="Orb3T"
                                     Storyboard.TargetProperty="X"
                                     From="0" To="-70" Duration="0:0:11"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb3T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="90" Duration="0:0:8"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Orb3"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.03" To="0.08" Duration="0:0:6"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <!-- ═══ МЕЛКИЕ ЧАСТИЦЫ ═══ -->
                    <DoubleAnimation Storyboard.TargetName="sp1T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-40" Duration="0:0:3"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp1"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.2" To="0.8" Duration="0:0:2"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="sp2T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-30" Duration="0:0:4"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp2"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="0.7" Duration="0:0:2.5"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="sp3T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-35" Duration="0:0:2.5"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp3"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.2" To="0.9" Duration="0:0:1.8"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="sp4T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-45" Duration="0:0:3.5"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp4"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.1" To="0.6" Duration="0:0:3"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="sp5T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-25" Duration="0:0:2"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp5"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="0.75" Duration="0:0:1.5"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <DoubleAnimation Storyboard.TargetName="sp6T"
                                     Storyboard.TargetProperty="Y"
                                     From="0" To="-50" Duration="0:0:4.5"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="sp6"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.1" To="0.5" Duration="0:0:3.5"
                                     AutoReverse="True" RepeatBehavior="Forever"/>

                    <!-- ═══ ПОЯВЛЕНИЕ UI ═══ -->
                    <!-- Лого появляется -->
                    <DoubleAnimation Storyboard.TargetName="LogoContainer"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.8"
                                     BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoContainerScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.6" To="1" Duration="0:0:0.8"
                                     BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoContainerScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.6" To="1" Duration="0:0:0.8"
                                     BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Заголовок -->
                    <DoubleAnimation Storyboard.TargetName="TitlePanel"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.7"
                                     BeginTime="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="TitlePanel"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,30,0,0" To="0,0,0,0"
                                        Duration="0:0:0.7"
                                        BeginTime="0:0:0.5">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>

                    <!-- Субтитр -->
                    <DoubleAnimation Storyboard.TargetName="SubtitleText"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"
                                     BeginTime="0:0:0.75">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Разделитель -->
                    <DoubleAnimation Storyboard.TargetName="Divider"
                                     Storyboard.TargetProperty="Width"
                                     From="0" To="280"
                                     Duration="0:0:1"
                                     BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="Divider"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="0.5" Duration="0:0:0.6"
                                     BeginTime="0:0:0.6"/>

                    <!-- Прогресс блок -->
                    <DoubleAnimation Storyboard.TargetName="ProgressPanel"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"
                                     BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="ProgressPanel"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,20,0,0" To="0,0,0,0"
                                        Duration="0:0:0.6"
                                        BeginTime="0:0:0.9">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>

                    <!-- Нижняя строка -->
                    <DoubleAnimation Storyboard.TargetName="BottomBar"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"
                                     BeginTime="0:0:1.1"/>

                    <!-- ═══ ТОЧКИ ЗАГРУЗКИ ═══ -->
                    <DoubleAnimation Storyboard.TargetName="dot1"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="1"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0"/>
                    <DoubleAnimation Storyboard.TargetName="dot2"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="1"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.17"/>
                    <DoubleAnimation Storyboard.TargetName="dot3"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.15" To="1"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.34"/>

                    <!-- Пульсация точек (размер) -->
                    <DoubleAnimation Storyboard.TargetName="dot1Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0"/>
                    <DoubleAnimation Storyboard.TargetName="dot1Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0"/>
                    <DoubleAnimation Storyboard.TargetName="dot2Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.17"/>
                    <DoubleAnimation Storyboard.TargetName="dot2Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.17"/>
                    <DoubleAnimation Storyboard.TargetName="dot3Scale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.34"/>
                    <DoubleAnimation Storyboard.TargetName="dot3Scale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1" To="1.5"
                                     Duration="0:0:0.5"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"
                                     BeginTime="0:0:0.34"/>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#07070F" Offset="0"/>
                <GradientStop Color="#0D0D20" Offset="0.5"/>
                <GradientStop Color="#090912" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- ═══ ФОН: ОРБЫ ═══ -->
        <Canvas IsHitTestVisible="False" ClipToBounds="True">

            <!-- Большие орбы -->
            <Ellipse x:Name="Orb1" Width="650" Height="650"
                     Canvas.Left="-200" Canvas.Top="-250" Opacity="0.07">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B6FD4" Offset="0"/>
                        <GradientStop Color="#5B3FA4" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb1T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="Orb2" Width="550" Height="550"
                     Canvas.Right="-180" Canvas.Bottom="-180" Opacity="0.05">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6B9FFF" Offset="0"/>
                        <GradientStop Color="#3B6FDF" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb2T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="Orb3" Width="400" Height="400"
                     Canvas.Left="350" Canvas.Top="150" Opacity="0.04">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF6B9D" Offset="0"/>
                        <GradientStop Color="#CF3B6D" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb3T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Мелкие частицы -->
            <Ellipse x:Name="sp1" Width="7" Height="7"
                     Canvas.Left="180" Canvas.Top="120" Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B6FD4" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp1T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="sp2" Width="5" Height="5"
                     Canvas.Left="650" Canvas.Top="280" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6B9FFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp2T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="sp3" Width="6" Height="6"
                     Canvas.Left="420" Canvas.Top="480" Opacity="0.35">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF6B9D" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp3T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="sp4" Width="4" Height="4"
                     Canvas.Left="820" Canvas.Top="160" Opacity="0.25">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B6FD4" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp4T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="sp5" Width="5" Height="5"
                     Canvas.Left="100" Canvas.Top="400" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6B9FFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp5T"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="sp6" Width="8" Height="8"
                     Canvas.Left="900" Canvas.Top="450" Opacity="0.2">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF6B9D" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="sp6T"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- ═══ ЦЕНТРАЛЬНЫЙ БЛОК ═══ -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <!-- ЛОГО -->
            <Grid x:Name="LogoContainer"
                  HorizontalAlignment="Center"
                  Width="160" Height="160"
                  Margin="0,0,0,36"
                  Opacity="0">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="LogoContainerScale" CenterX="80" CenterY="80"/>
                </Grid.RenderTransform>

                <!-- Внешнее свечение под всем -->
                <Ellipse Width="160" Height="160"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#8B6FD4" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect x:Name="OuterGlow" Radius="50"/>
                    </Ellipse.Effect>
                    <Ellipse.Opacity>0.2</Ellipse.Opacity>
                </Ellipse>

                <!-- Кольцо 4 (самое внешнее, медленное) -->
                <Ellipse Width="158" Height="158"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         StrokeThickness="1"
                         Opacity="0.12">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B6FD4" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.5"/>
                            <GradientStop Color="#6B9FFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring4Rotate" CenterX="79" CenterY="79"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Кольцо 3 -->
                <Ellipse Width="138" Height="138"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         StrokeThickness="1"
                         Opacity="0.2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FF6B9D" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring3Rotate" CenterX="69" CenterY="69"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Кольцо 2 -->
                <Ellipse Width="118" Height="118"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         StrokeThickness="1.5"
                         Opacity="0.35">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6B9FFF" Offset="0"/>
                            <GradientStop Color="#8B6FD4" Offset="0.5"/>
                            <GradientStop Color="#FF6B9D" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring2Rotate" CenterX="59" CenterY="59"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Кольцо 1 (самое внутреннее) -->
                <Ellipse Width="98" Height="98"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         StrokeThickness="2"
                         Opacity="0.5">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B6FD4" Offset="0"/>
                            <GradientStop Color="#6B9FFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="Ring1Rotate" CenterX="49" CenterY="49"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Сам логотип -->
                <Border Width="86" Height="86"
                        CornerRadius="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1040" Offset="0"/>
                            <GradientStop Color="#0E0825" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8B6FD4" Offset="0"/>
                            <GradientStop Color="#6B9FFF" Offset="0.5"/>
                            <GradientStop Color="#FF6B9D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1.5</Thickness>
                    </Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect x:Name="LogoGlow"
                                          Color="#8B6FD4"
                                          BlurRadius="30"
                                          ShadowDepth="0"
                                          Opacity="0.8"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="LogoScale" CenterX="43" CenterY="43"/>
                    </Border.RenderTransform>

                    <TextBlock Text="TH"
                               FontSize="34"
                               FontWeight="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C8A8FF" Offset="0"/>
                                <GradientStop Color="#8B6FD4" Offset="0.5"/>
                                <GradientStop Color="#6B9FFF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8B6FD4" BlurRadius="12"
                                              ShadowDepth="0" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- ЗАГОЛОВОК -->
            <StackPanel x:Name="TitlePanel"
                        HorizontalAlignment="Center"
                        Opacity="0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <TextBlock Text="HUNT"
                               FontSize="46" FontWeight="Black"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#C8A8FF" Offset="0"/>
                                <GradientStop Color="#8B6FD4" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#8B6FD4" BlurRadius="16"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text=" PROJECT"
                               FontSize="46" FontWeight="Black"
                               Foreground="#E8E8FF"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Субтитр -->
                <TextBlock x:Name="SubtitleText"
                           Text="Hunt Loader  •  v1.0.0"
                           FontSize="12"
                           Foreground="#555580"
                           HorizontalAlignment="Center"
                           Opacity="0"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Разделитель -->
            <Border x:Name="Divider"
                    Height="1" Width="0"
                    Margin="0,22,0,22"
                    HorizontalAlignment="Center"
                    Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#8B6FD4" Offset="0.35"/>
                        <GradientStop Color="#6B9FFF" Offset="0.65"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ПРОГРЕСС -->
            <StackPanel x:Name="ProgressPanel"
                        Width="380" Opacity="0">

                <!-- Статус -->
                <TextBlock x:Name="StatusLabel"
                           Text="Инициализация..."
                           Foreground="#9090BB"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Прогресс бар -->
                <Border CornerRadius="6" Height="6"
                        Background="#12122A"
                        Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="6"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <Border x:Name="ProgressFill"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            Width="0" Height="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#8B6FD4" Offset="0"/>
                                <GradientStop Color="#6B9FFF" Offset="0.5"/>
                                <GradientStop Color="#FF6B9D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#8B6FD4" BlurRadius="12"
                                              ShadowDepth="0" Opacity="1"/>
                        </Border.Effect>
                    </Border>
                </Border>

                <!-- Нижняя строка прогресса -->
                <Grid>
                    <TextBlock x:Name="PercentLabel"
                               Text="0%"
                               Foreground="#555580"
                               FontSize="11"
                               HorizontalAlignment="Left"/>

                    <!-- Точки -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Ellipse x:Name="dot1" Width="8" Height="8"
                                 Margin="5,0" Opacity="0.15"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#8B6FD4" Offset="0"/>
                                    <GradientStop Color="#6040A0" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#8B6FD4" BlurRadius="6"
                                                  ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="dot1Scale"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="dot2" Width="8" Height="8"
                                 Margin="5,0" Opacity="0.15"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#6B9FFF" Offset="0"/>
                                    <GradientStop Color="#3B6FDF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#6B9FFF" BlurRadius="6"
                                                  ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="dot2Scale"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <Ellipse x:Name="dot3" Width="8" Height="8"
                                 Margin="5,0" Opacity="0.15"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FF6B9D" Offset="0"/>
                                    <GradientStop Color="#CF3B6D" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF6B9D" BlurRadius="6"
                                                  ShadowDepth="0" Opacity="0.8"/>
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="dot3Scale"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </StackPanel>

                    <TextBlock x:Name="StepLabel"
                               Text="1/4"
                               Foreground="#555580"
                               FontSize="11"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- НИЖНЯЯ СТРОКА -->
        <Border x:Name="BottomBar"
                VerticalAlignment="Bottom"
                Padding="28,14"
                Opacity="0">
            <Grid>
                <TextBlock Text="© TH Project 2024"
                           Foreground="#252540"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="5" Height="5"
                             Fill="#8B6FD4"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#8B6FD4" BlurRadius="6"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Hunt Loader"
                               Foreground="#252540"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>