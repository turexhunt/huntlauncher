<!-- src/HuntLoader/Views/Pages/ConsolePage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.ConsolePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🖥 Консоль" Style="{StaticResource TitleStyle}" FontSize="22"/>
            <TextBlock Text="Вывод игры в реальном времени"
                       Style="{StaticResource SubtitleStyle}"/>
        </StackPanel>

        <!-- Тулбар -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Style="{StaticResource DarkTextBoxStyle}"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     Width="280" HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <CheckBox Content="Авто-прокрутка"
                          IsChecked="{Binding AutoScroll}"
                          Foreground="#888" FontSize="11"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>
                <Button Style="{StaticResource SecondaryBtnStyle}"
                        Command="{Binding CopyAllCommand}"
                        Content="📋" Width="36" Margin="0,0,4,0"
                        ToolTip="Скопировать всё"/>
                <Button Style="{StaticResource SecondaryBtnStyle}"
                        Command="{Binding SaveLogCommand}"
                        Content="💾" Width="36" Margin="0,0,4,0"
                        ToolTip="Сохранить лог"/>
                <Button Background="#33F44336" Foreground="#F44336"
                        BorderThickness="1" BorderBrush="#F44336"
                        Command="{Binding KillGameCommand}"
                        Content="⛔ Завершить" Padding="10,8"
                        Margin="0,0,4,0"/>
                <Button Style="{StaticResource SecondaryBtnStyle}"
                        Command="{Binding ClearCommand}"
                        Content="🗑 Очистить" Padding="10,8"/>
            </StackPanel>
        </Grid>

        <!-- Консольный вывод -->
        <Border Grid.Row="2" Background="#0A0A12"
                CornerRadius="10" BorderBrush="#222240"
                BorderThickness="1">
            <ListView ItemsSource="{Binding Lines}"
                      Background="Transparent"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      x:Name="ConsoleList">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="11" TextWrapping="NoWrap">
                            <Run Text="{Binding Prefix}"/>
                            <Run Text="{Binding Text}">
                                <Run.Foreground>
                                    <MultiBinding Converter="{StaticResource LineTypeToColor}">
                                        <Binding Path="Type"/>
                                    </MultiBinding>
                                </Run.Foreground>
                            </Run>
                        </TextBlock>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>
    </Grid>
</UserControl>