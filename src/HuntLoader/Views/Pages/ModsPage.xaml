<!-- src/HuntLoader/Views/Pages/ModsPage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="32,20,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="Black">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#8B6FD4" Offset="0"/>
                            <GradientStop Color="#6B9FFF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <Run Text="Менеджер модов"/>
                </TextBlock>
                <TextBlock Foreground="#555580" FontSize="12" Margin="0,4,0,0">
                    <Run Text="Профиль: "/>
                    <Run Text="{Binding CurrentProfile.Name, FallbackValue='—'}"
                         Foreground="#8B6FD4"/>
                    <Run Text="  •  Версия: "/>
                    <Run Text="{Binding CurrentProfile.GameVersion, FallbackValue='—'}"
                         Foreground="#6B9FFF"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Вкладки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">

            <!-- Установленные -->
            <Button Command="{Binding SwitchToInstalledCommand}"
                    Margin="0,0,8,0" Padding="18,10" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A1A2E"/>
                                    <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="0">
                                            <Setter Property="BorderBrush" Value="#8B6FD4"/>
                                            <Setter Property="Background" Value="#1E1A2E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Установленные"
                                           Foreground="#F0F0FF" FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border CornerRadius="8" Background="#8B6FD4"
                                        Padding="6,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Mods.Count}"
                                               Foreground="White"
                                               FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22223A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ✅ Modrinth — CommandParameter="modrinth" -->
            <Button Command="{Binding SwitchToSearchCommand}"
                    CommandParameter="modrinth"
                    Margin="0,0,8,0" Padding="18,10" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A1A2E"/>
                                    <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="1">
                                            <Setter Property="BorderBrush" Value="#1BD96A"/>
                                            <Setter Property="Background" Value="#0E1A10"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌿 " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Modrinth"
                                           Foreground="#F0F0FF" FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border CornerRadius="4" Background="#1BD96A"
                                        Padding="5,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="NEW" Foreground="#0A2A15"
                                               FontSize="9" FontWeight="Black"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0E1A10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ✅ CurseForge — CommandParameter="curseforge" -->
            <Button Command="{Binding SwitchToSearchCommand}"
                    CommandParameter="curseforge"
                    Padding="18,10" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A1A2E"/>
                                    <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTab}" Value="2">
                                            <Setter Property="BorderBrush" Value="#F16436"/>
                                            <Setter Property="Background" Value="#1A1008"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔥 " FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="CurseForge"
                                           Foreground="#F0F0FF" FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border CornerRadius="4" Background="#F16436"
                                        Padding="5,2" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="NEW" Foreground="White"
                                               FontSize="9" FontWeight="Black"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A1008"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Контент -->
        <Grid Grid.Row="2">

            <!-- ══ ВКЛАДКА: УСТАНОВЛЕННЫЕ (ActiveTab = 0) ══ -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Список установленных -->
                <Border Grid.Column="0" Margin="0,0,14,0"
                        Background="#0E0E1E" CornerRadius="14"
                        BorderBrush="#1E1E35" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Шапка -->
                        <Border Grid.Row="0" Padding="16,11"
                                BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock
                                    Text="{Binding Mods.Count, StringFormat='Установлено модов: {0}'}"
                                    Foreground="#555580" FontSize="12"
                                    VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Command="{Binding RefreshCommand}"
                                        Padding="10,5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="7"
                                                    Background="#161626"
                                                    BorderBrush="#252545" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="🔄 Обновить"
                                                           Foreground="#555580" FontSize="11"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#1E1E36"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Список -->
                        <ScrollViewer Grid.Row="1" Padding="12"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Mods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="14,10"
                                                Margin="0,0,0,6" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#161626"/>
                                                    <Setter Property="BorderBrush" Value="#1E1E35"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1E1E36"/>
                                                            <Setter Property="BorderBrush" Value="#8B6FD4"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0"
                                                         Width="7" Height="7"
                                                         Margin="0,0,12,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#5DBF8A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Fill" Value="#444466"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="#E0E0FF"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding SizeLabel}"
                                                               Foreground="#333355" FontSize="10"/>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Command="{Binding DataContext.ToggleModCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4" Margin="8,0,4,0"
                                                        Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" CornerRadius="6"
                                                                    Background="#1A1A2E"
                                                                    BorderBrush="#2A2A4A" BorderThickness="1"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <TextBlock FontSize="11" Foreground="#8080AA">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="⛔"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                                    <Setter Property="Text" Value="✅"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#252545"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Grid.Column="3"
                                                        Command="{Binding DataContext.DeleteModCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" CornerRadius="6"
                                                                    Background="#1A1018"
                                                                    BorderBrush="#2A1A1A" BorderThickness="1"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <TextBlock Text="🗑" FontSize="11"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="#33100A"/>
                                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#E86060"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Пусто -->
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModsEmpty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📦" FontSize="44" HorizontalAlignment="Center"/>
                            <TextBlock Text="Нет установленных модов"
                                       Foreground="#333355" FontSize="14"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,4"/>
                            <!-- ✅ ИСПРАВЛЕНО: передаём параметр "modrinth" -->
                            <Button Margin="0,14,0,0" Padding="16,9"
                                    Command="{Binding SwitchToSearchCommand}"
                                    CommandParameter="modrinth"
                                    Cursor="Hand" HorizontalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="9"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#8B6FD4" Offset="0"/>
                                                    <GradientStop Color="#6B9FFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="🔍 Найти моды"
                                                       Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Правая панель - папки -->
                <Border Grid.Column="1" Background="#0E0E1E" CornerRadius="14"
                        Padding="14" BorderBrush="#1E1E35" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Папки" Foreground="#E0E0FF"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <Button Padding="10,8" Cursor="Hand"
                                Command="{Binding OpenFolderCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="#161626"
                                            BorderBrush="#252545" BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="📂 Моды" Foreground="#8080AA" FontSize="12"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#8B6FD4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Padding="10,8" Cursor="Hand"
                                Command="{Binding OpenResourcePacks}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="#161626"
                                            BorderBrush="#252545" BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="🎨 Ресурспаки" Foreground="#8080AA" FontSize="12"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#8B6FD4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Padding="10,8" Cursor="Hand"
                                Command="{Binding OpenShaderPacks}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="#161626"
                                            BorderBrush="#252545" BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="✨ Шейдеры" Foreground="#8080AA" FontSize="12"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#8B6FD4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Padding="10,8" Cursor="Hand"
                                Command="{Binding OpenScreenshots}"
                                HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="#161626"
                                            BorderBrush="#252545" BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="📸 Скриншоты" Foreground="#8080AA" FontSize="12"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#8B6FD4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ВКЛАДКА: MODRINTH (ActiveTab = 1) ══ -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,14,0"
                        Background="#0E0E1E" CornerRadius="14"
                        BorderBrush="#1BD96A" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="14,12"
                                BorderBrush="#1E2E20" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="9"
                                        Background="#080818"
                                        BorderBrush="#1B3020" BorderThickness="1">
                                    <TextBox Background="Transparent"
                                             Foreground="#E0E0FF"
                                             CaretBrush="#1BD96A"
                                             BorderThickness="0"
                                             Padding="12,9" FontSize="13"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding SearchQuery,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding SearchCommand}"
                                        Padding="16,9" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="9"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#1BD96A" Offset="0"/>
                                                        <GradientStop Color="#16A855" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="🌿 Найти"
                                                           Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsSearching,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="🌿" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Поиск в Modrinth..."
                                           Foreground="#1BD96A" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="🌿" FontSize="44" HorizontalAlignment="Center"/>
                                <TextBlock Text="Введи название мода"
                                           Foreground="#333355" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                <TextBlock Text="Поиск по Modrinth"
                                           Foreground="#1BD96A" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding SearchResults}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="200" Margin="0,0,10,10"
                                                    CornerRadius="12" BorderThickness="1"
                                                    Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#161626"/>
                                                        <Setter Property="BorderBrush" Value="#1E1E35"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#0E1A10"/>
                                                                <Setter Property="BorderBrush" Value="#1BD96A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Margin="12">
                                                    <Border CornerRadius="4" Background="#1BD96A"
                                                            HorizontalAlignment="Left"
                                                            Padding="6,2" Margin="0,0,0,8">
                                                        <TextBlock Text="Modrinth"
                                                                   Foreground="#0A2A15"
                                                                   FontSize="9" FontWeight="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#E0E0FF"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DownloadsFormatted,
                                                                      StringFormat='⬇ {0}'}"
                                                               Foreground="#333355" FontSize="10"
                                                               Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#555580" FontSize="11"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,10"/>
                                                    <Button Command="{Binding DataContext.DownloadModCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="0,7" Cursor="Hand"
                                                            HorizontalAlignment="Stretch">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" CornerRadius="8"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <Border.Background>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                            <GradientStop Color="#1BD96A" Offset="0"/>
                                                                            <GradientStop Color="#16A855" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Border.Background>
                                                                    <TextBlock Text="⬇ Установить"
                                                                               Foreground="White"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Фильтры Modrinth -->
                <Border Grid.Column="1" Background="#0E0E1E" CornerRadius="14"
                        Padding="14" BorderBrush="#1E1E35" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Фильтры" Foreground="#E0E0FF"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <TextBlock Text="Загрузчик" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" Background="#080818"
                                BorderBrush="#1E1E35" BorderThickness="1" Margin="0,0,0,14">
                            <ComboBox ItemsSource="{Binding Loaders}"
                                      SelectedItem="{Binding SelectedLoader}"
                                      Background="Transparent" Foreground="#E0E0FF"
                                      BorderThickness="0" Padding="10,8" FontSize="12"/>
                        </Border>
                        <TextBlock Text="Версия игры" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" Background="#080818"
                                BorderBrush="#1E1E35" BorderThickness="1"
                                Padding="12,10" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentProfile.GameVersion,
                                               FallbackValue='Не выбран'}"
                                       Foreground="#1BD96A" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Height="1" Background="#1E1E35" Margin="0,0,0,14"/>
                        <TextBlock Text="Прогресс загрузки" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,8"/>
                        <Border CornerRadius="3" Height="5"
                                Background="#080818" ClipToBounds="True" Margin="0,0,0,8">
                            <Border CornerRadius="3" Height="5" HorizontalAlignment="Left">
                                <Border.Width>
                                    <Binding Path="DownloadProgress"
                                             Converter="{StaticResource PercentToWidth}"
                                             ConverterParameter="192"/>
                                </Border.Width>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1BD96A" Offset="0"/>
                                        <GradientStop Color="#16A855" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#1BD96A" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ ВКЛАДКА: CURSEFORGE (ActiveTab = 2) ══ -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveTab}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,14,0"
                        Background="#0E0E1E" CornerRadius="14"
                        BorderBrush="#F16436" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="14,12"
                                BorderBrush="#2E1E10" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="9"
                                        Background="#080818"
                                        BorderBrush="#2E1E10" BorderThickness="1">
                                    <TextBox Background="Transparent"
                                             Foreground="#E0E0FF"
                                             CaretBrush="#F16436"
                                             BorderThickness="0"
                                             Padding="12,9" FontSize="13"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding SearchQuery,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding SearchCommand}"
                                        Padding="16,9" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="9"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#F16436" Offset="0"/>
                                                        <GradientStop Color="#C84A20" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="🔥 Найти"
                                                           Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding IsSearching,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="🔥" FontSize="40" HorizontalAlignment="Center"/>
                                <TextBlock Text="Поиск в CurseForge..."
                                           Foreground="#F16436" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="🔥" FontSize="44" HorizontalAlignment="Center"/>
                                <TextBlock Text="Введи название мода"
                                           Foreground="#333355" FontSize="14"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                <TextBlock Text="Поиск по CurseForge"
                                           Foreground="#F16436" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ItemsControl ItemsSource="{Binding SearchResults}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="200" Margin="0,0,10,10"
                                                    CornerRadius="12" BorderThickness="1"
                                                    Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#161626"/>
                                                        <Setter Property="BorderBrush" Value="#1E1E35"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1A1008"/>
                                                                <Setter Property="BorderBrush" Value="#F16436"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Margin="12">
                                                    <Border CornerRadius="4" Background="#F16436"
                                                            HorizontalAlignment="Left"
                                                            Padding="6,2" Margin="0,0,0,8">
                                                        <TextBlock Text="CurseForge"
                                                                   Foreground="White"
                                                                   FontSize="9" FontWeight="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#E0E0FF"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DownloadsFormatted,
                                                                      StringFormat='⬇ {0}'}"
                                                               Foreground="#333355" FontSize="10"
                                                               Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#555580" FontSize="11"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,10"/>
                                                    <Button Command="{Binding DataContext.DownloadModCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="0,7" Cursor="Hand"
                                                            HorizontalAlignment="Stretch">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" CornerRadius="8"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <Border.Background>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                            <GradientStop Color="#F16436" Offset="0"/>
                                                                            <GradientStop Color="#C84A20" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Border.Background>
                                                                    <TextBlock Text="⬇ Установить"
                                                                               Foreground="White"
                                                                               FontSize="12" FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Фильтры CurseForge -->
                <Border Grid.Column="1" Background="#0E0E1E" CornerRadius="14"
                        Padding="14" BorderBrush="#1E1E35" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Фильтры" Foreground="#E0E0FF"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <TextBlock Text="Загрузчик" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" Background="#080818"
                                BorderBrush="#1E1E35" BorderThickness="1" Margin="0,0,0,14">
                            <ComboBox ItemsSource="{Binding Loaders}"
                                      SelectedItem="{Binding SelectedLoader}"
                                      Background="Transparent" Foreground="#E0E0FF"
                                      BorderThickness="0" Padding="10,8" FontSize="12"/>
                        </Border>
                        <TextBlock Text="Версия игры" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Border CornerRadius="8" Background="#080818"
                                BorderBrush="#1E1E35" BorderThickness="1"
                                Padding="12,10" Margin="0,0,0,20">
                            <TextBlock Text="{Binding CurrentProfile.GameVersion,
                                               FallbackValue='Не выбран'}"
                                       Foreground="#F16436" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Height="1" Background="#1E1E35" Margin="0,0,0,14"/>
                        <TextBlock Text="Прогресс загрузки" Foreground="#555580"
                                   FontSize="11" Margin="0,0,0,8"/>
                        <Border CornerRadius="3" Height="5"
                                Background="#080818" ClipToBounds="True" Margin="0,0,0,8">
                            <Border CornerRadius="3" Height="5" HorizontalAlignment="Left">
                                <Border.Width>
                                    <Binding Path="DownloadProgress"
                                             Converter="{StaticResource PercentToWidth}"
                                             ConverterParameter="192"/>
                                </Border.Width>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F16436" Offset="0"/>
                                        <GradientStop Color="#C84A20" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#F16436" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Статус бар -->
        <Border Grid.Row="3" Margin="0,10,0,0"
                Background="#0A0A18" CornerRadius="8"
                Padding="14,7" BorderBrush="#141428" BorderThickness="1">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#8B6FD4" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Border CornerRadius="3" Background="#0E1A10"
                            Padding="6,2" Margin="0,0,6,0">
                        <TextBlock Text="Modrinth" Foreground="#1BD96A" FontSize="10"/>
                    </Border>
                    <Border CornerRadius="3" Background="#1A1008" Padding="6,2">
                        <TextBlock Text="CurseForge" Foreground="#F16436" FontSize="10"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>