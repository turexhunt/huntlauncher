<!-- src/HuntLoader/Views/Pages/HomePage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="32,20,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ШАПКА ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="26" FontWeight="Black">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#9B7FE8" Offset="0"/>
                                <GradientStop Color="#5B8FE8" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                        <Run Text="HUNT"/>
                    </TextBlock>
                    <TextBlock Text=" LOADER"
                               FontSize="26" FontWeight="Black"
                               Foreground="#E8E8FF"/>
                </StackPanel>
                <TextBlock Text="Добро пожаловать обратно"
                           Foreground="#25FFFFFF" FontSize="12"
                           Margin="2,2,0,0"/>
            </StackPanel>
            <TextBlock Text="v2.0.0"
                       Foreground="#20FFFFFF"
                       FontSize="11"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- ═══ ЦЕНТР ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="285"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ ЛЕВАЯ ЧАСТЬ ═══ -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">

                <!-- Приветствие -->
                <TextBlock Text="{Binding WelcomeText, Mode=OneWay}"
                           FontSize="34" FontWeight="Black"
                           Foreground="#F0F0FF"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Готов к приключению?"
                           FontSize="13" Foreground="#25FFFFFF"
                           Margin="0,0,0,28"/>

                <!-- ── КАРТОЧКА ПРОФИЛЯ — Liquid Glass ── -->
                <Border CornerRadius="20" Padding="24,20"
                        Margin="0,0,0,16" ClipToBounds="False">
                    <!-- Тёмная подложка -->
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC0A0A1E" Offset="0"/>
                            <GradientStop Color="#CC070716" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#35FFFFFF" Offset="0"/>
                            <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#20FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#7C5CBF" BlurRadius="30"
                                          ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>

                    <Grid>
                        <!-- Glass highlight верх -->
                        <Border CornerRadius="20" Height="20"
                                VerticalAlignment="Top" Margin="1,1,1,0" Opacity="0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#25FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая часть -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="АКТИВНЫЙ ПРОФИЛЬ"
                                           Foreground="#25FFFFFF"
                                           FontSize="9" FontWeight="Black"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding ActiveProfile.Name,
                                               FallbackValue='Default', Mode=OneWay}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="#F0F0FF"
                                           Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Версия badge — glass -->
                                    <Border CornerRadius="8" Padding="12,5" Margin="0,0,8,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#207C5CBF" Offset="0"/>
                                                <GradientStop Color="#105B8FE8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#7C5CBF" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>
                                            <Thickness>1</Thickness>
                                        </Border.BorderThickness>
                                        <TextBlock Text="{Binding ActiveProfile.GameVersion,
                                                       FallbackValue='1.21.4', Mode=OneWay}"
                                                   Foreground="#9B7FE8"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- Лоадер badge -->
                                    <Border CornerRadius="8" Padding="12,5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#185B8FE8" Offset="0"/>
                                                <GradientStop Color="#104ECDC4" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#5B8FE8" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>
                                            <Thickness>1</Thickness>
                                        </Border.BorderThickness>
                                        <TextBlock Text="{Binding ActiveProfile.ModLoader,
                                                       FallbackValue='Fabric', Mode=OneWay}"
                                                   Foreground="#5B8FE8" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Правая часть — аккаунт -->
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="АККАУНТ"
                                           Foreground="#25FFFFFF" FontSize="9"
                                           FontWeight="Black"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding ActiveAccount.Username,
                                               FallbackValue='Не выбран', Mode=OneWay}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="#F0F0FF"
                                           HorizontalAlignment="Right"/>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,6,0,0">
                                    <Ellipse Width="7" Height="7"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0" Fill="#4ADE80">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#4ADE80"
                                                              BlurRadius="6"
                                                              ShadowDepth="0"
                                                              Opacity="0.8"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="{Binding ActiveAccount.TypeLabel,
                                                   FallbackValue='Offline', Mode=OneWay}"
                                               Foreground="#40FFFFFF" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ПРОГРЕСС -->
                <Grid Margin="0,0,0,12"
                      Visibility="{Binding IsLoading,
                          Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{Binding StatusText, Mode=OneWay}"
                               Foreground="#60FFFFFF" FontSize="12"
                               Margin="0,0,0,8"/>
                    <!-- Progress bar — glass -->
                    <Border Grid.Row="1" CornerRadius="4" Height="5"
                            ClipToBounds="True">
                        <Border.Background>
                            <SolidColorBrush Color="#18FFFFFF"/>
                        </Border.Background>
                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                Height="5"
                                Width="{Binding Progress, Mode=OneWay}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#9B7FE8" Offset="0"/>
                                    <GradientStop Color="#5B8FE8" Offset="0.6"/>
                                    <GradientStop Color="#4ECDC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C5CBF" BlurRadius="8"
                                                  ShadowDepth="0" Opacity="0.9"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </Grid>

                <!-- Статус -->
                <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                           Foreground="#30FFFFFF" FontSize="12"
                           Margin="0,0,0,22"
                           Visibility="{Binding IsLoading,
                               Converter={StaticResource InverseBoolToVis},
                               Mode=OneWay}"/>

                <!-- ── КНОПКИ ── -->
                <StackPanel Orientation="Horizontal">

                    <!-- ИГРАТЬ -->
                    <Button Command="{Binding PlayCommand}"
                            Width="200" Height="54"
                            Cursor="Hand" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <!-- Фон градиент -->
                                    <Border x:Name="bd" CornerRadius="16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#7C5CBF" Offset="0"/>
                                                <GradientStop Color="#5B8FE8" Offset="0.6"/>
                                                <GradientStop Color="#4ECDC4" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="GlowEffect"
                                                              Color="#7C5CBF"
                                                              BlurRadius="20"
                                                              ShadowDepth="0"
                                                              Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                    <!-- Glass highlight верх -->
                                    <Border CornerRadius="16" Height="18"
                                            VerticalAlignment="Top" Margin="2,2,2,0" Opacity="0.5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Контент -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="▶  "
                                                   FontSize="14"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="ИГРАТЬ"
                                                   FontSize="16"
                                                   FontWeight="Black"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="GlowEffect"
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.4" To="0.9"
                                                    Duration="0:0:2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="GlowEffect"
                                                    Storyboard.TargetProperty="BlurRadius"
                                                    From="16" To="38"
                                                    Duration="0:0:2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.72"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- СТОП — glass -->
                    <Button Command="{Binding StopCommand}"
                            Width="54" Height="54"
                            Cursor="Hand" Margin="0,0,8,0"
                            ToolTip="Остановить">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="16"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#18FFFFFF" Offset="0"/>
                                            <GradientStop Color="#06FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#25FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Rectangle Width="14" Height="14"
                                               Fill="#80FFFFFF" RadiusX="3" RadiusY="3"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.25"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ПАПКА — glass -->
                    <Button Command="{Binding OpenFolderCommand}"
                            Width="54" Height="54"
                            Cursor="Hand"
                            ToolTip="Открыть папку профиля">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="16"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#18FFFFFF" Offset="0"/>
                                            <GradientStop Color="#06FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#25FFFFFF" Offset="0"/>
                                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                              Stretch="Uniform" Fill="#80FFFFFF"/>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- ═══ ПРАВАЯ ЧАСТЬ ═══ -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                <!-- Статистика — Liquid Glass -->
                <Border CornerRadius="20" Padding="22,20" Margin="0,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC0A0A1E" Offset="0"/>
                            <GradientStop Color="#CC070714" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#30FFFFFF" Offset="0"/>
                            <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#18FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness><Thickness>1</Thickness></Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="30"
                                          ShadowDepth="4" Opacity="0.35"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Glass highlight верх -->
                        <Border Height="12" CornerRadius="20" Margin="-22,-20,-22,12"
                                VerticalAlignment="Top" Opacity="0.4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#20FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Ellipse Width="6" Height="6" Fill="#9B7FE8"
                                     VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#9B7FE8" BlurRadius="6"
                                                      ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="СТАТИСТИКА"
                                       Foreground="#30FFFFFF"
                                       FontSize="9" FontWeight="Black"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Наиграно"
                                           Foreground="#25FFFFFF" FontSize="10"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ActiveProfile.PlayTimeFormatted,
                                               FallbackValue='0м', Mode=OneWay}"
                                           FontSize="28" FontWeight="Black">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#9B7FE8" Offset="0"/>
                                            <GradientStop Color="#5B8FE8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Аккаунтов"
                                           Foreground="#25FFFFFF" FontSize="10"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding AccountsCount, Mode=OneWay}"
                                           FontSize="28" FontWeight="Black">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5B8FE8" Offset="0"/>
                                            <GradientStop Color="#4ECDC4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Быстрые действия — Liquid Glass -->
                <Border CornerRadius="20" Padding="22,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#CC0A0A1E" Offset="0"/>
                            <GradientStop Color="#CC070714" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#30FFFFFF" Offset="0"/>
                            <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#18FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness><Thickness>1</Thickness></Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="30"
                                          ShadowDepth="4" Opacity="0.35"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Ellipse Width="6" Height="6" Fill="#5B8FE8"
                                     VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#5B8FE8" BlurRadius="6"
                                                      ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="БЫСТРЫЕ ДЕЙСТВИЯ"
                                       Foreground="#30FFFFFF"
                                       FontSize="9" FontWeight="Black"/>
                        </StackPanel>

                        <!-- Папка модов -->
                        <Button Command="{Binding OpenModsFolderCommand}"
                                Height="40" Cursor="Hand" Margin="0,0,0,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="12"
                                            BorderThickness="1" Padding="14,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#15FFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#22FFFFFF" Offset="0"/>
                                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                                <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"
                                                      Stretch="Uniform" Fill="#9B7FE8"/>
                                            </Viewbox>
                                            <TextBlock Text="Папка модов"
                                                       FontSize="12"
                                                       Foreground="#D0D0F0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Сохранения -->
                        <Button Command="{Binding OpenSavesFolderCommand}"
                                Height="40" Cursor="Hand" Margin="0,0,0,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="12"
                                            BorderThickness="1" Padding="14,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#15FFFFFF" Offset="0"/>
                                                <GradientStop Color="#06FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#22FFFFFF" Offset="0"/>
                                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="14" Height="14" Margin="0,0,10,0">
                                                <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z"
                                                      Stretch="Uniform" Fill="#5B8FE8"/>
                                            </Viewbox>
                                            <TextBlock Text="Сохранения"
                                                       FontSize="12"
                                                       Foreground="#D0D0F0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Скриншоты -->
                        <Button Command="{Binding OpenScreenshotsFolderCommand}"
                                Height="40" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
