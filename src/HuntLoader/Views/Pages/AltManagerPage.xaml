<!-- src/HuntLoader/Views/Pages/AltManagerPage.xaml -->
<UserControl x:Class="HuntLoader.Views.Pages.AltManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,24">
            <TextBlock Text="Менеджер аккаунтов" Style="{StaticResource H1}"/>
            <TextBlock Text="Добавляй и управляй аккаунтами Minecraft"
                       Foreground="{StaticResource TextSecBrush}" FontSize="13"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Список -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,16,0"
                Background="#16162A" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,16,20,12"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding Accounts.Count, StringFormat='Аккаунтов: {0}'}"
                               Foreground="{StaticResource TextSecBrush}" FontSize="12"/>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="12">
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="16,14"
                                        Margin="0,0,0,6" Cursor="Hand"
                                        MouseLeftButtonDown="Account_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C35"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#222245"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Аватар -->
                                        <Border Grid.Column="0" Width="36" Height="36"
                                                CornerRadius="8">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#7C5CBF" Offset="0"/>
                                                    <GradientStop Color="#5C8CFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock FontSize="16" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <Binding Path="Username[0]"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>

                                        <!-- Инфо -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0">
                                            <TextBlock Text="{Binding Username}"
                                                       Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TypeLabel}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>

                                        <!-- Активен -->
                                        <Border Grid.Column="2" CornerRadius="6"
                                                Padding="8,3" VerticalAlignment="Center"
                                                Visibility="{Binding IsActive,
                                                    Converter={StaticResource BoolToVis}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#7C5CBF" Offset="0"/>
                                                    <GradientStop Color="#5C8CFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="АКТИВЕН" Foreground="White"
                                                       FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Правая панель -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Microsoft -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="⭐ Microsoft аккаунт"
                                   Style="{StaticResource H2}" Margin="0,0,0,4"/>
                        <TextBlock Text="Лицензионный аккаунт"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,16"/>
                        <Button Style="{StaticResource PrimaryBtn}"
                                Command="{Binding AddMicrosoftCommand}"
                                HorizontalAlignment="Stretch"
                                Content="Войти через Microsoft"/>
                    </StackPanel>
                </Border>

                <!-- Offline -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="👤 Offline аккаунт"
                                   Style="{StaticResource H2}" Margin="0,0,0,4"/>
                        <TextBlock Text="Без лицензии, 3-16 символов"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,0,0,12"/>
                        <TextBox Style="{StaticResource DarkInput}"
                                 Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>
                        <Button Style="{StaticResource SecondaryBtn}"
                                Command="{Binding AddOfflineCommand}"
                                HorizontalAlignment="Stretch"
                                Content="+ Добавить"/>
                    </StackPanel>
                </Border>

                <!-- Действия -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Действия" Style="{StaticResource H2}"
                                   Margin="0,0,0,12"/>
                        <Button Style="{StaticResource PrimaryBtn}"
                                Command="{Binding SetActiveCommand}"
                                HorizontalAlignment="Stretch"
                                Content="✅ Выбрать активным"
                                Margin="0,0,0,6"/>
                        <Button Style="{StaticResource SecondaryBtn}"
                                Command="{Binding CopyUsernameCommand}"
                                HorizontalAlignment="Stretch"
                                Content="📋 Копировать ник"
                                Margin="0,0,0,6"/>
                        <Button Style="{StaticResource DangerBtn}"
                                Command="{Binding RemoveCommand}"
                                HorizontalAlignment="Stretch"
                                Content="🗑 Удалить"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Статус -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="#16162A" CornerRadius="8" Padding="16,10"
                Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="12"/>
        </Border>
    </Grid>
</UserControl>