<!-- src/HuntLoader/Views/Dialogs/ColorPickerDialog.xaml -->
<Window x:Class="HuntLoader.Views.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор цвета"
        Width="340" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border CornerRadius="14" BorderThickness="1" BorderBrush="#2A2A4A">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0D1E" Offset="0"/>
                <GradientStop Color="#10101C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <StackPanel Margin="24">
            <!-- Шапка -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="🎨 Выбор цвета"
                           Foreground="#F0F0FF"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource WinBtnClose}"
                        Content="✕" Click="CloseClick"/>
            </Grid>

            <!-- Hex ввод -->
            <TextBlock Text="HEX код цвета (#RRGGBB)"
                       Foreground="#8888AA" FontSize="11"
                       Margin="0,0,0,8"/>
            <Border CornerRadius="9" Background="#080818"
                    BorderBrush="#2A2A4A" BorderThickness="1"
                    Margin="0,0,0,16">
                <TextBox x:Name="HexInput"
                         Background="Transparent"
                         Foreground="#F0F0FF"
                         CaretBrush="#8B6FD4"
                         BorderThickness="0"
                         Padding="12,10" FontSize="14"
                         FontFamily="Consolas"
                         MaxLength="7"
                         TextChanged="HexInput_TextChanged"/>
            </Border>

            <!-- Превью цвета -->
            <Border x:Name="ColorPreview"
                    Height="48" CornerRadius="10"
                    Margin="0,0,0,20">
                <TextBlock x:Name="PreviewLabel"
                           Text="Предпросмотр"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.7"/>
            </Border>

            <!-- Быстрые цвета -->
            <TextBlock Text="Быстрый выбор"
                       Foreground="#8888AA" FontSize="11"
                       Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,20">
                <Button Width="28" Height="28" Margin="3"
                        Tag="#7C5CBF" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#7C5CBF"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#5B8FE8" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#5B8FE8"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#E8609A" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#E8609A"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#4ECDC4" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#4ECDC4"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#2196F3" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#2196F3"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#4CAF50" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#4CAF50"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#FF9800" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#FF9800"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Width="28" Height="28" Margin="3"
                        Tag="#F44336" Click="QuickColor_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="6" Background="#F44336"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Отмена"
                        Style="{StaticResource SecondaryBtn}"
                        Click="CloseClick"/>
                <Button Grid.Column="2"
                        Content="✅ Применить"
                        Style="{StaticResource PrimaryBtn}"
                        Click="ApplyClick"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>