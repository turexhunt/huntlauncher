                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#D0AAFF" Offset="0"/>
                                    <GradientStop Color="#8B6FD4" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#8B6FD4"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0.9"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text=" PROJECT"
                                   FontSize="50" FontWeight="Black"
                                   Foreground="#E8E8FF"
                                   VerticalAlignment="Center"/>
