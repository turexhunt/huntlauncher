                        <Border x:Name="ProgFill"
                                CornerRadius="6"
                                HorizontalAlignment="Left"
                                Width="0" Height="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B6FD4" Offset="0"/>
                                    <GradientStop Color="#6B9FFF" Offset="0.5"/>
                                    <GradientStop Color="#FF6B9D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#8B6FD4"
                                                  BlurRadius="14"
                                                  ShadowDepth="0"
