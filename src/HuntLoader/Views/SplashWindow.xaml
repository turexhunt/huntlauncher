                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="dot1Sc"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="dot2"
                                     Width="8" Height="8"
                                     Margin="5,0" Opacity="0.15"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#6B9FFF" Offset="0"/>
                                        <GradientStop Color="#3B6FDF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#6B9FFF"
                                                      BlurRadius="8"
                                                      ShadowDepth="0"
                                                      Opacity="0.9"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="dot2Sc"/>
