                                     Margin="5,0" Opacity="0.15"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF6B9D" Offset="0"/>
                                        <GradientStop Color="#CF3B6D" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF6B9D"
                                                      BlurRadius="8"
                                                      ShadowDepth="0"
                                                      Opacity="0.9"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="dot3Sc"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>

                        <TextBlock x:Name="StepLbl"
                                   Text="1/5"
                                   Foreground="#444466" FontSize="11"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Нижняя строка -->
            <Border x:Name="BotBar"
                    VerticalAlignment="Bottom"
                    Padding="28,14"
                    Opacity="0">
                <Grid>
                    <!-- ← ГОД 2025 -->
                    <TextBlock Text="© TH Project 2025"
