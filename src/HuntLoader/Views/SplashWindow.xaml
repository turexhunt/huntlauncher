                               Foreground="#9090BB" FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <Border CornerRadius="6" Height="6"
                            Background="#10102A"
                            Margin="0,0,0,10">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="6"
                                              ShadowDepth="0"
                                              Opacity="0.7"/>
