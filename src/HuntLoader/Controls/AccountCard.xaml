<!-- src/HuntLoader/Controls/AccountCard.xaml -->
<UserControl x:Class="HuntLoader.Controls.AccountCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Аватар -->
            <Border Width="36" Height="36" CornerRadius="6"
                    Background="{StaticResource AccentBrush}">
                <TextBlock Text="{Binding Username[0]}"
                           Foreground="White" FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Инфо -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White" FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TypeLabel}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="11"/>
            </StackPanel>

            <!-- Статус -->
            <Border Grid.Column="2"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="4" Padding="6,2"
                    Visibility="{Binding IsActive,
                        Converter={StaticResource BoolToVis}}">
                <TextBlock Text="ACTIVE" Foreground="White"
                           FontSize="9" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Border>
</UserControl>